<?xml version="1.0" encoding="utf-8"?>
<!-- item_sale.xml / item_recent_sale.xml -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardElevation="2dp"
    app:cardCornerRadius="8dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="12dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:id="@+id/tv_customer" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textStyle="bold" android:textSize="15sp" android:textColor="#1A237E"/>
            <TextView android:id="@+id/tv_date" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textColor="#888"/>
        </LinearLayout>

        <TextView android:id="@+id/tv_sale_type" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:textColor="#444" android:paddingTop="2dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingTop="4dp">
            <TextView android:id="@+id/tv_amount" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textStyle="bold" android:textColor="#1B5E20"/>
            <TextView android:id="@+id/tv_paid" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="#555" android:textSize="13sp"/>
            <TextView android:id="@+id/tv_balance" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="#C62828" android:textSize="13sp"/>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
